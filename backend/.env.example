# Backend
APP_ENV=dev
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGINS=
# Optional: override with your own regex. Default is permissive for hosted deployments.
CORS_ALLOW_ORIGIN_REGEX=
DATA_DIR=/data
# Railway production must use PostgreSQL; SQLite remains suitable for local dev.
DATABASE_URL=
# Optional sqlite lock tuning (used only when DATABASE_URL is not set).
SQLITE_BUSY_TIMEOUT_MS=120000

# APIs
SUPADATA_API_KEY=
SUPADATA_BASE=https://api.supadata.ai/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
SEGMENT_ROUTING_MODE=hybrid
SEGMENT_HYBRID_PERCENT=100
SEGMENT_FLASH_MODEL=gemini-3.5-flash
SEGMENT_PRO_MODEL=gemini-3.1-pro-preview
SUPADATA_CHUNK_SIZE=50
# Clips are stored within the 1-180s safety envelope. The practice selector
# reads one whole transcript; there is no cue-batch configuration.
CLIP_SEARCH_MAX_VIDEOS=5
CLIP_SEARCH_BREADTH=3
INGEST_TOPIC_VIDEO_TIMEOUT_SEC=180
GENERATION_JOB_HEARTBEAT_SEC=15
GENERATION_JOB_LEASE_SEC=90
GENERATION_JOB_POLL_SEC=1

OPENAI_ENABLED=0
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: S3-compatible storage
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Secret key for HMAC-hashing verification codes. Required in hosted runtimes;
# set a long random value so a database leak cannot trivially recover 6-digit
# codes. Local dev auto-generates a secret under DATA_DIR if this is blank.
VERIFICATION_HMAC_KEY=

# Set to 1 to require email verification again. Default 0 bypasses verification
# and immediately activates accounts that provide an email address.
COMMUNITY_EMAIL_VERIFICATION_REQUIRED=0

# Required only when COMMUNITY_EMAIL_VERIFICATION_REQUIRED=1.
# Preferred: Resend HTTP API (works on Railway/Vercel where SMTP ports are blocked).
RESEND_API_KEY=
# Fallback: SMTP (used only when RESEND_API_KEY is empty).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=1
SMTP_USE_SSL=0
