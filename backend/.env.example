# Backend
APP_ENV=dev
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
DATA_DIR=./data
# Vercel note: DATA_DIR defaults to /tmp/studyreels-data automatically.

# APIs
OPENAI_ENABLED=0
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
YOUTUBE_API_KEY=

# Optional: S3-compatible storage
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
