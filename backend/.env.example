# Backend
APP_ENV=dev
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGINS=
# Optional: override with your own regex. Default is permissive for hosted deployments.
CORS_ALLOW_ORIGIN_REGEX=
DATA_DIR=./data
# Vercel note: DATA_DIR defaults to /tmp/studyreels-data automatically.
# Optional: Use Railway/Postgres in production instead of local sqlite.
DATABASE_URL=
# Optional sqlite lock tuning (used only when DATABASE_URL is not set).
SQLITE_BUSY_TIMEOUT_MS=120000

# APIs
OPENAI_ENABLED=0
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
YOUTUBE_API_KEY=

# Optional: S3-compatible storage
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Secret key for HMAC-hashing verification codes. Required in hosted runtimes;
# set a long random value so a database leak cannot trivially recover 6-digit
# codes. Local dev auto-generates a secret under DATA_DIR if this is blank.
VERIFICATION_HMAC_KEY=

# Required for hosted community-account email verification.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=1
SMTP_USE_SSL=0
