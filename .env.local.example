# Optional:
# - Local two-process dev (Next + uvicorn): set to http://localhost:8000
# - Split deploy (Vercel frontend + Railway backend): set NEXT_PUBLIC_DEPLOYED_API_BASE
# - Single Vercel project: set NEXT_PUBLIC_API_BASE only if you intentionally want direct cross-origin API calls
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_DEPLOYED_API_BASE=https://reelai-production.up.railway.app
