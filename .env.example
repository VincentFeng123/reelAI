# ── Default stack: Supadata transcript + Gemini selection + YouTube-embed clips ──
# Supadata key: https://supadata.ai
SUPADATA_API_KEY=sd_9e27085a86d9079f34521c190ed2e582

# Gemini key (free): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Providers (defaults shown)
TRANSCRIBER=supadata            # supadata | faster_whisper | groq
LLM_PROVIDER=gemini             # gemini | groq
GEMINI_MODEL=gemini-2.5-flash
EXPORT_RESOLUTION=1080          # resolution for on-demand .mp4 export

# Optional
FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
WHISPER_MODEL=small             # only if TRANSCRIBER=faster_whisper
GROQ_API_KEY=                   # only if a provider is set to "groq"
